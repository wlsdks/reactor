{
  "name": "@reactor/admin-web",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "verify:admin-api": "ADMIN_API_STRICT=1 node scripts/verify-admin-api-coverage.mjs",
    "verify:i18n": "node scripts/verify-i18n-keys.mjs",
    "verify:package-scripts": "node scripts/verify-package-scripts.mjs",
    "verify:release-tags": "node scripts/verify-release-tags.mjs",
    "verify:operator:live": "node scripts/verify-live-operator-stack.mjs",
    "verify:operator:stack": "pnpm verify:operator:live && pnpm test:e2e:live",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:live": "PLAYWRIGHT_LIVE_STACK=1 PLAYWRIGHT_BASE_URL=${PLAYWRIGHT_BASE_URL:-http://127.0.0.1:4174} PW_SKIP_WEBSERVER=1 playwright test e2e/live-operator-stack.spec.ts",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sentry/react": "^10.47.0",
    "@tanstack/react-query": "^5.90.21",
    "@xyflow/react": "^12.10.2",
    "i18next": "^25.8.4",
    "ky": "^1.14.3",
    "lucide-react": "^1.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.18.1",
    "react-window": "^2.2.7",
    "recharts": "^2.15.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "msw": "^2.15.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.5",
    "vitest": "^4.1.10"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
