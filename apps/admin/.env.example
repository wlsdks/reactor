# ============================================================
# Reactor Admin — Environment Variables
# ============================================================
# Copy this file to `.env` and adjust values for your setup.
# Vite exposes variables prefixed with VITE_ to the browser.
# ============================================================

# ----------------------------------------------------------
# Backend API
# ----------------------------------------------------------
# When empty, the Vite dev server proxies /api/* and /v3/api-docs
# to VITE_PROXY_TARGET. Set this to a full URL only when
# bypassing the proxy (e.g. in production Docker builds).
VITE_API_URL=

# Vite dev proxy target.
# Default: http://localhost:8000
# The monorepo FastAPI quick start uses port 8000.
VITE_PROXY_TARGET=http://localhost:8000

# Optional local operator API key. When set, admin requests send
# X-Reactor-API-Key so the UI can talk to Reactor's Python API without
# relying on a legacy Bearer JWT login flow.
VITE_REACTOR_API_KEY=

# ----------------------------------------------------------
# Mock Data (MSW)
# ----------------------------------------------------------
# Set to "true" to enable MSW browser mocking in dev mode.
# When enabled, API requests are intercepted and served from
# mock handlers in src/test/handlers/. Unhandled requests
# pass through to the real backend.
# VITE_MOCK=true

# ----------------------------------------------------------
# MCP Preset: Atlassian
# ----------------------------------------------------------
# Pre-filled values shown when registering the Atlassian MCP
# server via the admin UI. Adjust ports to match your local
# Atlassian MCP server instance.
VITE_ATLASSIAN_MCP_NAME=atlassian
VITE_ATLASSIAN_MCP_SSE_URL=http://localhost:8085/sse
VITE_ATLASSIAN_MCP_ADMIN_URL=http://localhost:8085

# ----------------------------------------------------------
# MCP Preset: Swagger
# ----------------------------------------------------------
# Pre-filled values shown when registering the Swagger MCP
# server via the admin UI.
VITE_SWAGGER_MCP_NAME=swagger
VITE_SWAGGER_MCP_SSE_URL=http://localhost:8081/sse
VITE_SWAGGER_MCP_ADMIN_URL=http://localhost:8081

# ----------------------------------------------------------
# Testing — Playwright
# ----------------------------------------------------------
# PLAYWRIGHT_BASE_URL: Override the base URL for Playwright
# e2e tests. Default: http://127.0.0.1:3001
# PW_SKIP_WEBSERVER: Set to any value to skip auto-starting
# the dev server (useful when running against an external URL).
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3001
# PW_SKIP_WEBSERVER=1

# ----------------------------------------------------------
# Testing — Operator Stack
# ----------------------------------------------------------
# Used by e2e tests that validate against a full operator
# stack (Reactor backend + MCP servers).
# `verify-live-operator-stack.mjs` currently reads only the
# Reactor admin API base plus admin credentials.
# OPERATOR_STACK_API_BASE=http://localhost:8000
# OPERATOR_STACK_ADMIN_EMAIL=admin@example.com
# OPERATOR_STACK_ADMIN_PASSWORD=admin1234

# ----------------------------------------------------------
# reactor-iam URL (required for IAM login in all environments)
# ----------------------------------------------------------
# In dev: set to http://localhost:18082 in .env.local
# Unset: falls back to direct Reactor login
VITE_IAM_URL=
