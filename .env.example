REACTOR_ENVIRONMENT=local
REACTOR_HOST=127.0.0.1
REACTOR_PORT=8000
REACTOR_RELOAD=false

# Local development can run without Postgres/Redis. Production should provide both.
REACTOR_DATABASE_URL=postgresql://reactor:reactor@localhost:5432/reactor
REACTOR_DATABASE_REQUIRED=false
REACTOR_REDIS_URL=redis://localhost:6379/0
REACTOR_REDIS_REQUIRED=false

# Provider keys are intentionally optional in local development.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Local Ollama can be used without provider API keys when the model is pulled locally.
# Example: ollama run gemma4:12b
# REACTOR_DEFAULT_MODEL_PROVIDER=ollama
# REACTOR_DEFAULT_MODEL=gemma4:12b

# Eval LLM judge is opt-in so local/CI can run without provider credentials.
REACTOR_EVAL_LLM_JUDGE_ENABLED=false
REACTOR_EVAL_LLM_JUDGE_PROVIDER=openai
REACTOR_EVAL_LLM_JUDGE_MODEL=gpt-5-mini

# Dynamic scheduler is opt-in and requires Postgres-backed scheduler stores.
REACTOR_SCHEDULER_ENABLED=false
REACTOR_SCHEDULER_POLL_INTERVAL_SECONDS=60
REACTOR_SCHEDULER_LEASE_OWNER=reactor-scheduler
REACTOR_SCHEDULER_TENANT_IDS=[]

# Alert evaluation scheduler is opt-in and uses Postgres-backed alert rules/instances.
REACTOR_ALERT_SCHEDULER_ENABLED=false
REACTOR_ALERT_SCHEDULER_INTERVAL_SECONDS=60

# PromptLab auto-optimization scheduler is opt-in and runs configured/all templates.
REACTOR_PROMPT_LAB_SCHEDULER_ENABLED=false
REACTOR_PROMPT_LAB_SCHEDULER_INTERVAL_SECONDS=86400
REACTOR_PROMPT_LAB_SCHEDULER_TENANT_IDS=[]
REACTOR_PROMPT_LAB_SCHEDULER_USER_ID=system
REACTOR_PROMPT_LAB_SCHEDULER_TEMPLATE_IDS=[]
REACTOR_PROMPT_LAB_SCHEDULER_CANDIDATE_COUNT=3
REACTOR_PROMPT_LAB_SCHEDULER_JUDGE_MODEL=

# Slack integration is opt-in. Use xoxb-* for Web API calls and xapp-* for Socket Mode.
REACTOR_SLACK_BOT_TOKEN=
REACTOR_SLACK_APP_TOKEN=
REACTOR_SLACK_SIGNING_SECRET=
REACTOR_SLACK_SOCKET_MODE_ENABLED=false
REACTOR_SLACK_REQUIRE_CHANNEL_MENTION=true
REACTOR_SLACK_ALLOWED_CHANNEL_IDS=[]
REACTOR_SLACK_FREE_RESPONSE_CHANNEL_IDS=[]
REACTOR_SLACK_ALLOWED_USER_IDS=[]
